# Data folder path (SQLite DB + JSON migration files). Defaults to backend/data/ if unset.
DATA_DIR=C:\path\to\your\data\folder

# Jira Configuration
JIRA_HOST=https://your-jira-instance.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token-here

# Jira Filter IDs
JIRA_FILTER_ID_SPRINT=60259
JIRA_FILTER_ID_ME=47216
JIRA_FILTER_ID_DEFECTS=57474
JIRA_FILTER_ID_ARCHIVE=56341

# Daily summary ingest key (used by scheduled job POST /api/daily-summary)
DAILY_SUMMARY_API_KEY=replace-with-strong-shared-key

# Server Configuration
PORT=3050
NODE_ENV=development

# Daily summary mode: 'file' reads a local .md file, 'api' uses the DB record
DAILY_SUMMARY_MODE=file
DAILY_SUMMARY_FILE_PATH=C:\Users\smagar\Documents\Claude\Scheduled\daily-morning-briefing\dailyBriefing.md
